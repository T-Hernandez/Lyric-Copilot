# ============================================================
# SUPABASE
# Obtené estos valores en: supabase.com → tu proyecto → Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# PROVEEDOR LLM
# El router intenta PRIMARY, luego FALLBACK_ORDER si hay rate limit (429)
# ============================================================
LLM_PRIMARY_PROVIDER=gemini          # gemini | groq | openrouter | ollama
LLM_FALLBACK_ORDER=gemini,groq,openrouter

GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ============================================================
# SOLO DESARROLLO LOCAL (nunca usar en producción)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
USE_OLLAMA_IN_DEV=false
